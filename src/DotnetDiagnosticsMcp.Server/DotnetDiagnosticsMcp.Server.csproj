<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <UserSecretsId>dotnet-diagnostics-mcp-server</UserSecretsId>
    <Description>MCP server exposing dotnet-diagnostics-mcp Core tools via Streamable HTTP transport.</Description>
    <RootNamespace>DotnetDiagnosticsMcp.Server</RootNamespace>
    <AssemblyName>DotnetDiagnosticsMcp.Server</AssemblyName>
  </PropertyGroup>

  <!-- Packaging (issue #27): published to NuGet as a .NET global tool. Consumers install
       with `dotnet tool install -g DotnetDiagnosticsMcp.Server` and invoke
       `dotnet-diagnostics-mcp` from PATH. The tool command shim is generated by the
       SDK when PackAsTool=true. -->
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>dotnet-diagnostics-mcp</ToolCommandName>
    <PackageId>DotnetDiagnosticsMcp.Server</PackageId>
    <Authors>pedrosakuma</Authors>
    <Company>pedrosakuma</Company>
    <PackageProjectUrl>https://github.com/pedrosakuma/dotnet-diagnostics-mcp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/pedrosakuma/dotnet-diagnostics-mcp</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>mcp;diagnostics;dotnet;performance;profiling;cpu;gc;eventpipe</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Description>MCP server that attaches to running .NET processes (CoreCLR or NativeAOT) over the diagnostic IPC socket and exposes on-demand performance diagnostics (CPU sampling, EventCounters, GC events, exceptions, dumps, heap drilldown). No target-side instrumentation required.</Description>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ModelContextProtocol" />
    <PackageReference Include="ModelContextProtocol.AspNetCore" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DotnetDiagnosticsMcp.Server.IntegrationTests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DotnetDiagnosticsMcp.Core\DotnetDiagnosticsMcp.Core.csproj" />
  </ItemGroup>

</Project>
